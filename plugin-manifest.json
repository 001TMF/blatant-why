{
  "name": "proteus-agent",
  "version": "0.1.0",
  "description": "Proteus protein design agent — conversational protein and antibody design with custom scoring",
  "author": "Proteus",
  "tools": {
    "protenix": {
      "description": "AF3-class structure prediction with Protenix v1",
      "engine": "Protenix",
      "env_var": "PROTEUS_FOLD_DIR",
      "install": "https://github.com/bytedance/Protenix"
    },
    "pxdesign": {
      "description": "De novo protein binder design with PXDesign",
      "engine": "PXDesign",
      "env_var": "PROTEUS_PROT_DIR",
      "install": "https://github.com/bytedance/PXDesign"
    },
    "boltzgen": {
      "description": "Antibody/nanobody design with BoltzGen + Protenix",
      "engine": "BoltzGen",
      "env_var": "PROTEUS_AB_DIR",
      "install": "https://github.com/HannesStark/boltzgen"
    }
  },
  "mcpServers": [
    "pdb",
    "uniprot",
    "sabdab",
    "proteus-screening",
    "tamarind",
    "levitate",
    "adaptyv",
    "proteus-campaign",
    "proteus-research",
    "proteus-local"
  ],
  "skills": [
    "proteus-design-workflow",
    "proteus-scoring",
    "proteus-epitope-analysis",
    "proteus-screening",
    "proteus-campaign-manager",
    "proteus-database",
    "protenix",
    "pxdesign",
    "boltzgen"
  ],
  "scoring": {
    "ipSAE": {
      "description": "TM-align-inspired interface score from PAE matrices",
      "range": [0.0, 1.0],
      "thresholds": {"poor": 0.3, "good": 0.5, "excellent": 0.8}
    },
    "p_bind": {
      "description": "ML binding probability from Protenix trunk features",
      "range": [0.0, 1.0],
      "thresholds": {"unlikely": 0.3, "likely": 0.5, "high_confidence": 0.8},
      "status": "awaiting_training"
    }
  },
  "modes": ["binder", "antibody", "structure"],
  "commands": ["/watch", "/status", "/results", "/screen"]
}
